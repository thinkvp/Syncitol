{
  "manifestVersion": 6,
  "id": "com.thinkvp.syncitol",
  "name": "Syncitol",
  "version": "1.1.0",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "26.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "syncitol.panel",
      "label": { "default": "Syncitol" },
      "minimumSize": { "width": 320, "height": 400 },
      "preferredDockedSize": { "width": 360, "height": 640 },
      "preferredFloatingSize": { "width": 380, "height": 720 }
    }
  ],
  "addon": {
    "name": "syncitol.uxpaddon"
  },
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "enableAddon": true,
    "allowCodeGenerationFromStrings": false
  }
}
